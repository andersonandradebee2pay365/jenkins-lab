pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Clonando repositório...'
            }
        }

        stage('Build') {
            steps {
                echo 'Executando build...'
            }
        }

        stage('Test') {
            steps {
                echo 'Executando testes...'
            }
        }
    }
}